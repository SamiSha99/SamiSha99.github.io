---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function excerpt(markdown, wordCount = 32) {
    const plain = markdown
        .replace(/```[\s\S]*?```/g, " ")
        .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
        .replace(/<[^>]*>/g, " ")
        .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1")
        .replace(/[#>*_~`]/g, " ")
        .replace(/\s+/g, " ")
        .trim();
    const words = plain.split(" ");
    return words.length > wordCount ? words.slice(0, wordCount).join(" ") + "..." : plain;
}

function formatDate(date) {
    return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

function postHref(post) {
    return `/blog/${post.id}/`;
}
---

<BaseLayout title="Blog" description="Sami's little corner :3">
    <h1>Blog</h1>
    <ul class="post-list">
        {
            posts.map((post) => (
                <li>
                    <span class="post-meta">{formatDate(post.data.date)}</span>
                    <h2>
                        <a class="post-link" href={postHref(post)}>
                            {post.data.title}
                        </a>
                    </h2>
                    <p>{excerpt(post.body || "")}</p>
                </li>
            ))
        }
    </ul>
</BaseLayout>
